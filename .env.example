# Trends Boutique — Local Environment Variables
# Copy this to .env.local and fill in values for local development.
# For Vercel deployment, set these in the Vercel dashboard → Settings → Environment Variables.

# Google Gemini API key for AI Virtual Try-On feature
# Get your key at: https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# WhatsApp number with country code (no +, spaces, or dashes)
# Example: 91999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=
